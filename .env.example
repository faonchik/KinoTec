# Database connection string
DATABASE_URL="postgresql://username:password@localhost:5432/kinoteka_db?schema=public"

# NextAuth configuration
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Groq AI SDK Key (for movie recommendations)
GROQ_API_KEY=""

# TMDB (The Movie Database) API Key (v3 API key or Read Access Token JWT)
TMDB_API_KEY=""
# Optional outbound proxy for TMDB requests if running behind restrictions (e.g. in Russia)
# TMDB_OUTBOUND_PROXY="http://127.0.0.1:7890"

# Telegram Bot configuration for moderation and administration
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_ID=""

# SMTP Email configurations (for password recovery, notifications)
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""

# Unsplash API key for backgrounds/covers
UNSPLASH_ACCESS_KEY=""

# Google reCAPTCHA configuration
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
